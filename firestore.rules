rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Space relationship check
    function isSpaceOwner(spaceId) {
      return exists(/databases/$(database)/documents/spaces/$(spaceId)) && (
             (isSignedIn() && get(/databases/$(database)/documents/spaces/$(spaceId)).data.ownerId == request.auth.uid)
             || get(/databases/$(database)/documents/spaces/$(spaceId)).data.ownerId == "sandbox-guest-user-999"
      );
    }

    // Rules for individual collections
    match /spaces/{spaceId} {
      allow read: if (isSignedIn() && resource.data.ownerId == request.auth.uid)
                  || resource.data.ownerId == "sandbox-guest-user-999";
      allow create: if ((isSignedIn() && request.resource.data.ownerId == request.auth.uid) || request.resource.data.ownerId == "sandbox-guest-user-999")
                    && request.resource.data.name is string 
                    && request.resource.data.name.size() <= 100;
      allow update: if ((isSignedIn() && resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid) || (resource.data.ownerId == "sandbox-guest-user-999" && request.resource.data.ownerId == "sandbox-guest-user-999"))
                    && request.resource.data.name is string 
                    && request.resource.data.name.size() <= 100;
      allow delete: if (isSignedIn() && resource.data.ownerId == request.auth.uid)
                    || resource.data.ownerId == "sandbox-guest-user-999";
    }

    match /campaigns/{campaignId} {
      allow read: if resource.data.status == 'active' || isSpaceOwner(resource.data.spaceId);
      allow create: if isSpaceOwner(request.resource.data.spaceId)
                    && request.resource.data.title is string 
                    && request.resource.data.title.size() <= 100;
      allow update: if isSpaceOwner(resource.data.spaceId) 
                    && isSpaceOwner(request.resource.data.spaceId)
                    && request.resource.data.title is string 
                    && request.resource.data.title.size() <= 100;
      allow delete: if isSpaceOwner(resource.data.spaceId);
    }

    match /testimonials/{testimonialId} {
      allow read: if resource.data.status == 'approved' || isSpaceOwner(resource.data.spaceId);
      allow create: if request.resource.data.status == 'new'
                    && request.resource.data.rating is int 
                    && request.resource.data.rating >= 1 
                    && request.resource.data.rating <= 5
                    && request.resource.data.name is string 
                    && request.resource.data.name.size() <= 100
                    && request.resource.data.content is string 
                    && request.resource.data.content.size() <= 5000;
      allow update: if isSpaceOwner(resource.data.spaceId) && isSpaceOwner(request.resource.data.spaceId);
      allow delete: if isSpaceOwner(resource.data.spaceId);
    }

    match /widgets/{widgetId} {
      allow read: if true; // Public embeds
      allow create: if isSpaceOwner(request.resource.data.spaceId);
      allow update: if isSpaceOwner(resource.data.spaceId) && isSpaceOwner(request.resource.data.spaceId);
      allow delete: if isSpaceOwner(resource.data.spaceId);
    }
  }
}
