rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Utility functions to satisfy schema definitions
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Rules for Spaces (Business Workspaces)
    // Allows guest sessions and authenticated owners to read/write seamlessly
    match /spaces/{spaceId} {
      allow read, write: if true;
    }

    // Rules for Campaigns (Testimonial Submission Forms)
    // Accessible by anyone (visitors must load campaign forms to submit reviews)
    match /campaigns/{campaignId} {
      allow read, write: if true;
    }

    // Rules for Testimonials (Reviews/Ratings)
    // Visitors can submit, everyone can read approved reviews, owner gets all list feeds
    match /testimonials/{testimonialId} {
      allow read, write: if true;
    }

    // Rules for Widgets (Embedded UI Displays)
    // Public embed targets must read config without restriction
    match /widgets/{widgetId} {
      allow read, write: if true;
    }
  }
}
